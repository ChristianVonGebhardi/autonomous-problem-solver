# LicenseGuard Environment Configuration

# API Configuration
API_SECRET_KEY=dev-secret-key-change-in-production
API_HOST=0.0.0.0
API_PORT=8000

# Database
DATABASE_URL=postgresql://licenseguard:licenseguard@localhost:5432/licenseguard
POSTGRES_USER=licenseguard
POSTGRES_PASSWORD=licenseguard
POSTGRES_DB=licenseguard

# Redis
REDIS_URL=redis://localhost:6379/0

# OpenAI (for remediation suggestions)
OPENAI_API_KEY=your-openai-api-key-here

# Detection Configuration
SIMILARITY_THRESHOLD=0.75
MINHASH_NUM_PERM=128
EMBEDDING_MODEL=all-MiniLM-L6-v2

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Worker Configuration
WORKER_CONCURRENCY=4