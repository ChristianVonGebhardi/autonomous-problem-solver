# Copy this file to .env and fill in values for local development.
# Never commit .env to the repository.

# Required for both Actions runner and Railway worker
ANTHROPIC_API_KEY=sk-ant-...

# Required for Railway worker only (PAT with repo scope)
# The Actions runner uses the built-in GITHUB_TOKEN instead
GH_PAT=github_pat_...

# Repository coordinates
REPO_OWNER=ChristianVonGebhardi
REPO_NAME=autonomous-problem-solver

# Optional tuning
POLL_INTERVAL_SECONDS=60
