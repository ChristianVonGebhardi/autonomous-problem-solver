# Database
DATABASE_URL=postgresql://localhost/drift_detection

# Optional: OpenAI for LLM drift explanations (gated behind alerts only)
OPENAI_API_KEY=

# Drift detection thresholds
DRIFT_ALERT_THRESHOLD=0.65
STRUCTURAL_WEIGHT=0.35
SEMANTIC_WEIGHT=0.40
DISTRIBUTIONAL_WEIGHT=0.25

# CUSUM / EWMA parameters
EWMA_ALPHA=0.3
CUSUM_THRESHOLD=5.0
CUSUM_SLACK=1.0

# Worker settings
WORKER_POLL_INTERVAL=2
WORKER_BATCH_SIZE=10

# API settings
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Embedding model (local sentence-transformers, no API needed)
EMBEDDING_MODEL=all-MiniLM-L6-v2