# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here

# Database
DATABASE_URL=postgresql+asyncpg://scopecreep:scopecreep@localhost:5432/scopecreep
SYNC_DATABASE_URL=postgresql://scopecreep:scopecreep@localhost:5432/scopecreep

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=your-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# App
APP_ENV=development
FRONTEND_URL=http://localhost:5173

# Optional: SendGrid for email delivery
SENDGRID_API_KEY=
FROM_EMAIL=noreply@yourdomain.com

# Optional: AWS S3 for file storage (falls back to local storage if not set)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=scope-creep-contracts

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0