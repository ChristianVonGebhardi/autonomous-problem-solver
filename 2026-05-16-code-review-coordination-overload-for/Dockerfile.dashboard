FROM golang:1.21-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /dashboard ./cmd/dashboard

FROM alpine:3.19
RUN apk --no-cache add ca-certificates tzdata
COPY --from=builder /dashboard /dashboard
EXPOSE 8085
ENTRYPOINT ["/dashboard"]