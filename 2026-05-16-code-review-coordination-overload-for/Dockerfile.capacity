FROM golang:1.21-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /capacity ./cmd/capacity

FROM alpine:3.19
RUN apk --no-cache add ca-certificates tzdata
COPY --from=builder /capacity /capacity
EXPOSE 8083
ENTRYPOINT ["/capacity"]