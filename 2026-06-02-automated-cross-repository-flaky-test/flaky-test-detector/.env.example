# Database
DATABASE_URL=postgresql://flaky:flaky123@localhost:5432/flaky_tests
REDIS_URL=redis://localhost:6379

# OpenAI (leave blank to use mock mode)
OPENAI_API_KEY=

# GitHub (leave blank to use mock mode)
GITHUB_TOKEN=
GITHUB_APP_ID=

# LLM Settings
MOCK_LLM=true
LLM_MODEL=gpt-4o
LLM_MAX_TOKENS=2048

# GitHub PR Bot
MOCK_GITHUB=true

# Worker Settings
WORKER_POLL_INTERVAL=5
FIX_WORKER_POLL_INTERVAL=10

# Flakiness Detection Thresholds
MIN_RUNS_FOR_DETECTION=3
FLAKINESS_THRESHOLD=0.3
CONFIDENCE_THRESHOLD=0.6

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000