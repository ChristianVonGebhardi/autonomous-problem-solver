# === LLM Configuration ===
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o
USE_OLLAMA=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=codellama

# === GitHub Integration ===
GITHUB_TOKEN=ghp_your_github_token_here

# === Database Configuration ===
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password123

QDRANT_HOST=localhost
QDRANT_PORT=6333

POSTGRES_URL=postgresql://codeknow:codeknow@localhost:5432/codeknow
DATABASE_URL=postgresql+asyncpg://codeknow:codeknow@localhost:5432/codeknow

# === Redis / Celery ===
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# === Embedding Configuration ===
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# === API Settings ===
API_SECRET_KEY=change-me-to-a-random-secret-key
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# === Ingestion Settings ===
MAX_FILE_SIZE_KB=500
CHUNK_SIZE=512
CHUNK_OVERLAP=64
MAX_COMMITS_PER_INGEST=500